# MySQL database
# Option A: single connection URL
MYSQL_URL=mysql://root:password@localhost:3306/cargo_fleet

# Option B: individual settings (used when MYSQL_URL is empty)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cargo_fleet

# Auth (use: openssl rand -base64 32)
AUTH_SECRET=
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN_SEC=3600
JWT_REFRESH_EXPIRES_IN_DAYS=30

# SMTP — forgot password emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Cargo Fleet <your-email@gmail.com>"
APP_NAME=Cargo Fleet

# Google Sign-In (Web + mobile client IDs from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# App URL (optional, for future web reset links)
APP_URL=http://localhost:3000
